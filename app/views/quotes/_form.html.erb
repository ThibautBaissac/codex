<%= form_with(model: quote, id: "quote_form_#{quote&.id}") do |form| %>
  <% if quote.errors.any? %>
    <% quote.errors.each do |error| %>
      <div class="alert alert-warning alert-dismissible fade show position-relative top-0 start-0" role="alert">
        <%= error.full_message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% end %>
  <% end %>

  <%= hidden_field_tag :mouvement_id, mouvement.id %>
  <%= form.text_field :title, class: "form-control form-control-text-area d-block mt-3", rows: 10, placeholder: "Titre" %>
  <%= form.text_area :description, class: "form-control form-control-text-area d-block mt-3", rows: 10, placeholder: "Description" %>
  <%= form.text_area :history, class: "form-control form-control-text-area d-block mt-3", rows: 10, placeholder: "Histoire" %>

  <div class="d-flex justify-content-between mt-3">
    <div>
      <%= form.collection_check_boxes :category, Quote.category_values, :to_s, :humanize do |b| %>
        <div class="form-check">
          <%= b.label(:"data-value" => b.value, class: "check_box") { b.check_box(class: "form-check-input") + b.text } %>
        </div>
      <% end %>
    </div>

    <div class="d-flex flex-column">
      <div class="flex-grow-1">
        <div class="form-check">
          <%= form.radio_button :popular, true, checked: quote.popular, id: "populaire", type: "radio", class: "form-check-input" %>
          <%= form.label "Populaire", for: "populaire", class: "form-check-label" %>
        </div>
        <div class="form-check">
          <%= form.radio_button :popular, false, checked: quote.popular, id: "savante", type: "radio", class: "form-check-input" %>
          <%= form.label "Savante", for: "savante", class: "form-check-label" %>
        </div>
      </div>

      <div>
        <div class="form-check">
          <%= form.radio_button :with_influence, true, checked: quote.with_influence, id: "with_influence", type: "radio", class: "form-check-input" %>
          <%= form.label "Avec influence", for: "with_influence", class: "form-check-label" %>
        </div>
        <div class="form-check">
          <%= form.radio_button :with_influence, false, checked: quote.with_influence, id: "without_influence",  type: "radio", class: "form-check-input" %>
          <%= form.label "Sans influence", for: "without_influence", class: "form-check-label" %>
        </div>
      </div>
    </div>
  </div>
  <%= quote_instrumentation_options(quote) %>
<% end %>
