<div id="<%= "quote_#{dom_id(quote)}_container" %>">
  <%= turbo_frame_tag dom_id(quote) do %>
    <div class="card card-hover">
      <div class="d-flex justify-content-between align-items-center">
        <h3><%= quote&.title %></h3>
        <div>
          <%= quote.instrumentation&.map{|instrument| t("intrumentation.#{instrument.downcase}")&.capitalize}&.join(", ") %>
          <%= link_to(icon('fa-solid', 'edit'), edit_quote_path(quote),
              class: "ms-2") if policy(quote).edit? %>
        </div>
      </div>
      <div id="quotes">
        <% quote.mouvements.each do |mouvement| %>
          <%= link_to("#{mouvement.work&.title} : #{mouvement.title}", work_path(mouvement.work), class: "link-secondary text-decoration-none") %>
        <% end %>
        <p class="text-secondary">
          <%= quote&.description %>
        </p>
        <div>Histoire :
          <p class="text-secondary">
          <%= quote&.history %>
          </p>
        </div>
      </div>
    </div>
  <% end %>
</div>
