<div class="col-6 mx-auto mt-3">
  <%= form_tag sessions_path do %>
    <h1 class="h3 mb-3 fw-normal text-center">Connexion</h1>
    <div class="mb-3">
      <%= email_field_tag :email, nil, placeholder: "Email", class: 'form-control', required: true, autofocus: true %>
    </div>
    <div class="mb-3">
      <%= password_field_tag :password, nil, placeholder: "Mot de passe", class: 'form-control', id: 'password_input', required: true %>
    </div>
    <label>
      <input type="checkbox" onclick="myFunction()"> Voir le mot de passe
    </label>
    <div class="mt-3">
      <%= submit_tag "Login", id: "new_session_commit", class: "btn btn-primary rounded-pill w-100" %>
    </div>
  <% end %>
</div>
<script>
  function myFunction() {
    var x = document.getElementById("password_input");
    if (x.type === "password") {
      x.type = "text";
    } else {
      x.type = "password";
    }
  }
</script>
