<div class="col-lg-8 mt-3 mx-auto">
  <h1><%= @element.title %></h1>

  <div>Description :
    <p class="text-secondary">
      <%= my_format(@element&.description) %>
    </p>
  </div>
  <div><%= category_label(@element) %></div>
  <div><%= popular_label(@element) %></div>
  <div><%= with_influence_label(@element) %></div>

  <div class="my-3 py-3 border-top">
    <h4>Œuvres et Mouvements</h4>
    <% @element.mouvements.each do |mouvement| %>
      <%= link_to(mouvement.work.title, work_path(mouvement.work)) %>
      -
      <%= mouvement.number %>. <%= mouvement.title %>
    <% end %>
  </div>
</div>
